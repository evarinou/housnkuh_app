{
  "name": "housnkuh-client",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.13",
    "@testing-library/user-event": "^13.5.0",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.17",
    "@types/react-calendar": "^3.9.0",
    "@types/react-datepicker": "^6.2.0",
    "axios": "^1.6.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "formik": "^2.4.9",
    "framer-motion": "^12.11.4",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.510.0",
    "react": "^18.2.0",
    "react-calendar": "^6.0.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-intersection-observer": "^9.16.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.30.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.15.3",
    "web-vitals": "^2.1.4",
    "yup": "^1.7.1"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "build:ci": "CI=false craco build",
    "test": "craco test",
    "eject": "react-scripts eject",
    "lint": "eslint src/ --ext .ts,.tsx --max-warnings 175",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "prettier"
    ],
    "overrides": [
      {
        "files": ["**/*.test.ts", "**/*.test.tsx"],
        "rules": {
          "testing-library/no-node-access": "warn",
          "testing-library/no-wait-for-multiple-assertions": "warn",
          "testing-library/no-container": "warn",
          "testing-library/no-render-in-setup": "warn",
          "testing-library/prefer-find-by": "warn",
          "testing-library/no-wait-for-side-effects": "warn",
          "jest/no-conditional-expect": "warn"
        }
      }
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-leaflet|@react-leaflet|date-fns)/)"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@locator/babel-jsx": "^0.4.4",
    "@tailwindcss/postcss": "^4.1.6",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^27.5.2",
    "@types/json-schema": "^7.0.15",
    "@types/lodash": "^4.17.17",
    "@types/node": "^16.18.126",
    "@types/parse-json": "^7.0.0",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^4.9.5"
  },
  "proxy": "http://localhost:4000"
}
