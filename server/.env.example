# Server Configuration
PORT=4000
NODE_ENV=development

# Öffentliche Basis-URL des Servers (für extern erreichbare Bild-URLs,
# z. B. Produktbilder im Flourio-Sync). Fallback: FRONTEND_URL
# PUBLIC_SERVER_URL=https://housnkuh.de

# Database
MONGO_URI=mongodb://localhost:27017/housnkuh

# Authentication
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
ADMIN_SETUP_KEY=your_admin_setup_key_here

# Email Configuration (if needed)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Sprint S12_M11_Mietfaecher_Seeding_Cleanup - Development Seeding Control
# Set to 'true' for development environments that need sample Mietfächer data
# IMPORTANT: Only works when NODE_ENV=development
SEED_MIETFAECHER=false

# Flourio API v3 Configuration
# Get your Bearer Token from developer@flour.io
FLOURIO_BEARER_TOKEN=your_flourio_bearer_token_here
FLOURIO_API_URL=https://flour.host/v3

# Flourio API Settings (Optional)
# FLOURIO_TIMEOUT=30000
# FLOURIO_RETRY_ATTEMPTS=3
# FLOURIO_RATE_LIMIT_PER_MINUTE=60

# CORS Configuration (comma-separated origins for production)
# CORS_ORIGINS=https://housnkuh.de,https://www.housnkuh.de

# Production Notes:
# - Never set SEED_MIETFAECHER=true in production
# - Always create Mietfächer manually through admin interface in production
# - Use strong, unique values for JWT_SECRET and ADMIN_SETUP_KEY
# - Keep FLOURIO_BEARER_TOKEN secure - never commit to Git!